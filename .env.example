# ── Production Environment Variables ──────────────────────────────────────────

# Database Configuration
POSTGRES_USER=airflow
POSTGRES_PASSWORD=changeme123_use_strong_password
POSTGRES_DB=airflow_db

# Backend Configuration
DATABASE_URL=postgresql://airflow:changeme123_use_strong_password@db:5432/airflow_db
SECRET_KEY=your-secret-key-change-in-production-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
ALLOWED_ORIGINS=https://airflowanalysis.xyz,https://www.airflowanalysis.xyz

# Email Configuration (Gmail App Password recommended)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@gmail.com
ADMIN_EMAIL=admin@airflowanalysis.xyz

# Frontend Configuration
VITE_API_URL=https://airflowanalysis.xyz/api

# Optional: Redis (for caching/sessions)
# REDIS_URL=redis://redis:6379/0
